# IBM i Client - Environment Configuration Example
# Copy this file to .env and fill in your IBM i system details

# =============================================
# IBM i Connection Settings
# =============================================
VITE_IBMI_HOST=localhost
VITE_IBMI_PORT=23
VITE_IBMI_TIMEOUT=30000

# =============================================
# API Server Settings
# =============================================
VITE_API_URL=http://localhost:3001/api
VITE_API_TIMEOUT=30000

# =============================================
# DEMO MODE (No Backend Required)
# =============================================
# Set to "true" to enable demo mode that works WITHOUT a backend server
# Useful for testing the UI without setting up the backend
# VITE_DEMO_MODE=true

# =============================================
# Green Screen Display Settings
# =============================================
VITE_SCREEN_ROWS=24
VITE_SCREEN_COLS=80

# =============================================
# UI/Theme Settings
# =============================================
# Options: light | dark
VITE_THEME=light

# =============================================
# Logging Settings
# =============================================
# Options: debug | info | warn | error
VITE_LOG_LEVEL=info

# =============================================
# Example Production Settings
# =============================================
# VITE_IBMI_HOST=as400.company.com
# VITE_IBMI_PORT=992
# VITE_API_URL=https://api.company.com/ibmi
# VITE_THEME=dark
