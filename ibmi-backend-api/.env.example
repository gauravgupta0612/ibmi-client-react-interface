# Backend API Configuration
PORT=3001
NODE_ENV=development

# IBM i Connection Settings
IBMI_HOST=10.5.11.40
IBMI_PORT=23
IBMI_DEFAULT_LIBRARY=QGPL
IBMI_TIMEOUT=30000

# iTookit Integration Configuration
# Set USE_REAL_CONNECTION to 'true' to enable real IBM i connections via iTookit
# Requires: npm install itoolkit idb-connector
# Note: iTookit requires C++ native modules (node-gyp) and Visual Studio Build Tools on Windows
USE_REAL_CONNECTION=false

# Real IBM i System Credentials (when USE_REAL_CONNECTION=true)
IBMI_SYSTEM_HOST=10.5.11.40
IBMI_SYSTEM_PORT=22
IBMI_SYSTEM_USER=ggpta
IBMI_SYSTEM_PASSWORD=gguptas

# Database Connection Settings (for idb-connector)
IBMI_DB_HOST=10.5.11.40
IBMI_DB_PORT=8471
IBMI_DB_USER=ggupta
IBMI_DB_PASS=gguptas
IBMI_DB_LIB=QSYS2

# API Settings
API_CORS_ORIGIN=http://localhost:5173
API_LOG_LEVEL=info

# Session Settings
SESSION_TIMEOUT=3600000
SESSION_CHECK_INTERVAL=60000

